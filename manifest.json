{
  "manifest_version": "0.4",
  "name": "apple-ecosystem-mcp",
  "display_name": "Apple Ecosystem",
  "version": "0.1.5",
  "description": "MCP server for Apple Mail, Calendar, Contacts, Reminders, and iCloud Drive",
  "author": {
    "name": "Abhinav Agrawal"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/abhinavag-svg/apple-ecosystem-mcp.git"
  },
  "server": {
    "type": "python",
    "entry_point": "server/runner.py",
    "mcp_config": {
      "command": "uvx",
      "args": ["--refresh-package", "apple-ecosystem-mcp", "apple-ecosystem-mcp@0.1.5"]
    }
  },
  "compatibility": {
    "platforms": ["darwin"]
  },
  "privacy_policies": [
    { "url": "https://github.com/abhinavag-svg/apple-ecosystem-mcp/blob/main/PRIVACY.md" }
  ],
  "icon": "logo.svg",
  "license": "MIT"
}
